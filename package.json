{
  "name": "fixit-hub",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "apps/api",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=frontend",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm run build --workspaces",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
